[sqlfluff]
templater = jinja
dialect = duckdb
max_line_length = 120
# ST06 (select column order) and RF04 (keyword identifiers) are noisy for dbt staging models.
exclude_rules = structure.column_order, references.keywords

[sqlfluff:indentation]
tab_space_size = 4
indent_unit = space

[sqlfluff:templater:jinja]
# Stub ref/source/config/var so models template without a dbt compile.
apply_dbt_builtins = true
# Load project macros (e.g. cents_to_dollars) so models template without a dbt compile.
load_macros_from_path = projects/finance/macros,projects/marketing/macros,projects/operations/macros

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = lower
