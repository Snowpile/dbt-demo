# =============================================================================
# dbt_demo — gitignore
# Local env, warehouse files, and build artifacts stay out of git.
# Examples/templates that *are* committed: .env.example, profiles.yml.example
# =============================================================================

# --- secrets & local config (never commit) ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets/
# dbt profile with absolute paths (use profiles.yml.example instead)
profiles.yml
dbt_profiles.yml
**/profiles.yml

# --- dbt build / deps / state (regenerated locally or by CI) ---
target/
dbt_packages/
logs/
# Local slim/defer manifests: ./scripts/pull_state.sh → state/<mart_*>/
state/
manifest.json
catalog.json
run_results.json
semantic_manifest.json
.partial_parse.msgpack

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.envrc
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# --- warehouse / data artifacts (local only) ---
# Keep seeds under data/seeds/; everything else under data/ is local DuckDB etc.
data/*
!data/seeds/
!data/seeds/**
*.parquet
*.avro
*.orc
*.duckdb
*.duckdb.wal
*.wal
*.sqlite
*.db
!**/seeds/**/*.csv
!**/seeds/**/*.parquet

# --- Spark / notebooks (unused in this demo; ignore if created locally) ---
.spark/
metastore_db/
derby.log

# --- OS & editors ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
# Cursor UI / MCP local overrides (project AI instructions live in AGENTS.md)
.cursor/
.cursorignore.bak

# --- AI local overrides (machine-specific; keep AGENTS.md + CLAUDE.md shim in git) ---
AGENTS.override.md
CLAUDE.local.md
.claude/
.user.yml
