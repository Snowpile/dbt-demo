dbt_demo:
  target: qa
  outputs:
    # QA and prod share one DuckDB file. Layer schemas (source_data, mart, …) are
    # identical; branch/PR work uses --defer + dev_schema sandbox (see docs/defer.md).
    qa:
      type: duckdb
      path: "{{ env_var('DUCKDB_PROD_PATH', 'data/prod.duckdb') }}"
      threads: 4
    prod:
      type: duckdb
      path: "{{ env_var('DUCKDB_PROD_PATH', 'data/prod.duckdb') }}"
      threads: 4

# Copy to profiles.yml (gitignored). Per-project profile name must match
# profile: in each mart_<domain>/dbt_project.yml
