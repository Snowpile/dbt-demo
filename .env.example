# Copy to .env (gitignored). Paths must be absolute when running dbt from projects/<domain>/.
DBT_PROFILES_DIR=/absolute/path/to/benderik
DUCKDB_DEV_PATH=/absolute/path/to/benderik/data/dev.duckdb
DUCKDB_STAGING_PATH=/absolute/path/to/benderik/data/staging.duckdb
DUCKDB_PROD_PATH=/absolute/path/to/benderik/data/prod.duckdb
