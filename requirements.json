        "dbt-duckdb==1.10.1",
        "duckdb==1.5.4"
    ],
    "extras_require": {
        "dev": [
            "ruff==0.15.18",
            "pre-commit==3.6.2"
        ],
        "prefect": [
            "prefect>=3.0,<4"
        ],
        "airflow": [
